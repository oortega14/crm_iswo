# ============================================================================
# CRM ISWO — variables de entorno de ejemplo
# Copiar a .env y completar. NUNCA commitear .env con valores reales.
# ============================================================================

# Base de datos
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm_iswo_development

# Redis (Sidekiq + cache + cable)
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_ENV=development
RAILS_LOG_LEVEL=debug

# Secrets — generar con: bin/rails secret
SECRET_KEY_BASE=
DEVISE_JWT_SECRET_KEY=

# Lockbox — generar con: Lockbox.generate_key
LOCKBOX_MASTER_KEY=

# Blind Index — generar con: BlindIndex.generate_key
BLIND_INDEX_MASTER_KEY=

# CORS (orígenes del SPA React separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Email (Postmark)
POSTMARK_API_TOKEN=
MAIL_FROM=no-reply@crm.iswo.com.co

# WhatsApp (Twilio por default; cambiar a cloud_api en F3 si aplica)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Storage (para exportaciones y thumbnails de landing pages)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=crm-iswo-dev

# Host / subdominios
APP_HOST=crm.iswo.com.co
DEFAULT_TENANT_SLUG=iswo
