<h2 style="margin-top:0;">Hola <%= @user.first_name.presence || @user.email %>,</h2>

<p>Tienes un recordatorio que vence ahora:</p>

<p style="background:#f3f4f6; padding:12px 16px; border-radius:8px;">
  <strong><%= @reminder.title %></strong><br>
  <span class="muted">Programado para: <%= I18n.l(@reminder.remind_at, format: :long) rescue @reminder.remind_at %></span>
</p>

<% if @reminder.body.present? %>
  <p><%= simple_format(@reminder.body) %></p>
<% end %>

<% if @opportunity %>
  <p>
    <strong>Oportunidad:</strong> <%= @opportunity.title %><br>
    <% if @contact %>
      <strong>Contacto:</strong>
      <%= [@contact.first_name, @contact.last_name].compact.join(" ") %>
      <% if @contact.phone_e164.present? %>(<%= @contact.phone_e164 %>)<% end %>
      <% if @contact.email.present? %>· <%= @contact.email %><% end %>
    <% end %>
  </p>
<% end %>

<p style="margin-top:24px;">
  Abre el CRM para revisarlo y marcarlo como completado.
</p>
